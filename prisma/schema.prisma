// ─────────────────────────────────────────────────────────────
// GAMIFICATION: ABANDONED CART LOG
// ─────────────────────────────────────────────────────────────

model AbandonedCartLog {
  id        String @id @default(uuid())
  orderId   String
  userId    String?
  email     String  @db.VarChar(255)

  sentAt    DateTime?
  status    String @default("PENDING") @db.VarChar(20) // PENDING, SENT, CONVERTED, EXPIRED

  couponCode String? @db.VarChar(50) // Gönderilen kupon kodu (varsa)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([orderId])
  @@map("abandoned_cart_logs")
}

// ─────────────────────────────────────────────────────────────
// VIP ABONELİK SİSTEMİ (Subscription)
// ─────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

/// Admin tarafından oluşturulan VIP abonelik planları.
/// Her plan bir MemberType'a bağlıdır — satın alındığında kullanıcı o tipe yükseltilir.
model SubscriptionPlan {
  id                 String     @id @default(uuid())
  name               String     @db.VarChar(200) // "Aylık VIP", "Yıllık Gold"
  description        String?
  price              Decimal    @db.Decimal(12, 4) // Varsayılan fiyat (fallback)
  currency           Currency   @default(TRY)      // Varsayılan para birimi
  durationDays       Int        // 30, 90, 365 vb.

  // Bu plan satın alındığında kullanıcı bu tipe geçer
  targetMemberTypeId String
  targetMemberType   MemberType @relation(fields: [targetMemberTypeId], references: [id])

  // Opsiyonel avantajlar
  bonusPoints        Int        @default(0) // Abonelik başlangıcında hediye puan
  features           Json?      // ["Özel fiyatlar", "%10 ekstra indirim", "Öncelikli destek"]

  isActive           Boolean    @default(true)
  sortOrder          Int        @default(0)

  // Çoklu para birimi fiyatları
  prices        SubscriptionPrice[]
  subscriptions UserSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscription_plans")
}

/// Ülke/para birimi bazlı abonelik fiyatları.
/// Her plan için birden fazla currency fiyatı tanımlanabilir.
model SubscriptionPrice {
  id        String           @id @default(uuid())
  planId    String
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  currency  Currency         // TRY, USD, EUR, GBP, SAR vb.
  price     Decimal          @db.Decimal(12, 4) // O para birimindeki fiyat
  country   String?          @db.VarChar(5) // İsteğe bağlı ülke kodu (tr, us, de)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, currency])
  @@index([currency])
  @@map("subscription_prices")
}

/// Kullanıcıların aktif/geçmiş abonelikleri.
/// Süre bittiğinde cron job memberTypeId'yi "Bireysel"e geri döndürür.
model UserSubscription {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String
  plan      SubscriptionPlan   @relation(fields: [planId], references: [id])

  startDate DateTime           @default(now())
  endDate   DateTime
  status    SubscriptionStatus @default(ACTIVE)

  // Ödeme referansı
  paymentRef  String? @db.VarChar(200)
  paidAmount  Decimal @default(0) @db.Decimal(12, 4)

  // Süresi dolduğunda eski tipe dönmek için
  previousMemberTypeId String? @db.VarChar(100)

  cancelledAt DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([endDate, status])
  @@map("user_subscriptions")
}

// ─────────────────────────────────────────────────────────────
// AFFILIATE / REFERANS SİSTEMİ
// ─────────────────────────────────────────────────────────────

enum AffiliateStatus {
  PENDING   // Sipariş onaylandı, komisyon beklemede
  APPROVED  // Admin onayladı, cüzdana eklendi
  REJECTED  // Admin reddetti
}

/// Komisyon kademe tablosu — Admin belirler
model AffiliateTier {
  id                 String  @id @default(uuid())
  name               String  @db.VarChar(100) // "Normal Üye", "VIP Yayıncı", "Platin Affiliate"
  commissionPercent  Decimal @db.Decimal(5, 2) // %1, %3, %5
  minWithdrawAmount  Decimal @default(50) @db.Decimal(12, 4) // Min para çekme tutarı
  isDefault          Boolean @default(false)
  isActive           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("affiliate_tiers")
}

/// Her başarılı siparişten referer'a yazılan komisyon kaydı
model AffiliateTransaction {
  id               String          @id @default(uuid())
  orderId          String
  referrerUserId   String
  referrer         User            @relation("AffiliateEarner", fields: [referrerUserId], references: [id], onDelete: Cascade)

  orderAmount      Decimal         @db.Decimal(12, 4) // Sipariş toplamı
  commissionRate   Decimal         @db.Decimal(5, 2)  // Uygulanan oran (%)
  commissionAmount Decimal         @db.Decimal(12, 4) // Kazanılan tutar
  currency         Currency        @default(TRY)

  status           AffiliateStatus @default(PENDING)
  approvedAt       DateTime?
  approvedBy       String?         // Admin userId
  paidToWallet     Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerUserId, status])
  @@index([orderId])
  @@map("affiliate_transactions")
}

// ═══════════════════════════════════════════════════════════════
// 📧 EMAIL MARKETING & ANALYTICS ENGINE
// ═══════════════════════════════════════════════════════════════

enum EmailType {
  WELCOME                // Hoş geldin
  EMAIL_VERIFICATION     // E-posta doğrulama/OTP
  ORDER_CONFIRMATION     // Sipariş onayı
  ORDER_DELIVERY         // E-pin teslimi
  GUEST_ORDER_INFO       // Misafir sipariş bilgi
  PASSWORD_RESET         // Şifre sıfırlama
  ACCOUNT_DELETION       // Üyelik iptali
  ABANDONED_CART_1H      // Terk edilen sepet (1 saat)
  ABANDONED_CART_24H     // Terk edilen sepet (24 saat)
  RE_ENGAGEMENT          // Geri dön kampanyası
  CAMPAIGN               // Manuel kampanya
  BALANCE_LOADED         // Bakiye yüklendi
  REFERRAL_EARNED        // Referans komisyonu
}

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum CampaignTargetType {
  ALL_USERS
  ACTIVE_USERS           // Son 30 gün aktif
  INACTIVE_USERS         // 30+ gün inaktif
  VIP_MEMBERS            // Belirli MemberType
  DEALERS                // Bayiler
  NEW_USERS              // Son 7 gün üye olan
  CUSTOM_SEGMENT         // Özel segmentasyon (JSON filter)
}

/// E-posta şablonları — Tüm transactional ve marketing maillerin HTML'leri
model EmailTemplate {
  id          String    @id @default(uuid())
  tenantIds   Json?
  slug        String    @unique @db.VarChar(100) // "welcome", "order-confirmation", "abandoned-cart-1h"
  name        String    @db.VarChar(200)         // Görünen ad: "Hoş Geldin Maili"
  subject     String    @db.VarChar(500)         // "Hoş geldin {{firstName}}!"
  bodyHtml    String    @db.Text                 // Full HTML template (Handlebars/Mustache vars)
  description String?   @db.VarChar(500)         // Admin notları

  emailType   EmailType                          // Hangi tetikleyici için kullanılır
  isActive    Boolean   @default(true)
  version     Int       @default(1)              // Versiyon takibi

  // Çoklu dil desteği
  languageCode String  @default("tr") @db.VarChar(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, languageCode])
  @@index([emailType, isActive])
  @@map("email_templates")
}

/// E-posta kampanyaları — Admin takviminden planlanan toplu gönderimler
model EmailCampaign {
  id            String             @id @default(uuid())
  tenantIds     Json?
  title         String             @db.VarChar(300)
  description   String?

  // İçerik
  subject       String             @db.VarChar(500)
  bodyHtml      String             @db.Text
  previewText   String?            @db.VarChar(200) // Gmail önizleme

  // Hedef kitle
  targetType    CampaignTargetType @default(ALL_USERS)
  targetFilter  Json?              // Özel filtre: {"memberTypeId": "...", "countryCode": "TR"}
  targetCount   Int?               // Hesaplanan alıcı sayısı

  // Zamanlama
  scheduledAt   DateTime?          // null = taslak, belirlenmişse o tarihte gider
  sentAt        DateTime?          // Gerçek gönderim zamanı

  // Metrikler (Aggregate — EmailLog'dan hesaplanır)
  totalSent     Int @default(0)
  totalOpened   Int @default(0)
  totalClicked  Int @default(0)
  totalBounced  Int @default(0)

  // Dönüşüm
  conversions   Int     @default(0) // Mailden sipariş tamamlayan sayısı
  revenue       Decimal @default(0) @db.Decimal(14, 4) // Kampanyadan elde edilen ciro

  status        CampaignStatus @default(DRAFT)
  createdById   String?        // Admin userId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs EmailLog[]

  @@index([status])
  @@index([scheduledAt])
  @@index([createdById])
  @@map("email_campaigns")
}

/// E-posta gönderim logları — Her tekil mail gönderimi + açılma/tıklanma takibi
model EmailLog {
  id            String      @id @default(uuid())
  tenantId      String?

  userId        String?     // Kayıtlı kullanıcı (null = misafir)
  email         String      @db.VarChar(255) // Alıcı e-posta adresi (snapshot)
  emailType     EmailType                    // Mail tipi

  // İçerik (snapshot — değişen şablonlardan etkilenmez)
  subject       String      @db.VarChar(500)
  templateSlug  String?     @db.VarChar(100) // Hangi şablondan oluşturuldu

  // Kampanya ilişkisi (opsiyonel)
  campaignId    String?
  campaign      EmailCampaign? @relation(fields: [campaignId], references: [id])

  // Durum takibi
  status        EmailStatus @default(QUEUED)
  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?   // Tracking pixel tetiklendi
  clickedAt     DateTime?   // Link tıklandı

  // Tracking
  trackingId    String      @unique @default(uuid()) // Pixel ve link tracking için unique ID
  openCount     Int         @default(0)  // Kaç kez açıldı
  clickCount    Int         @default(0)  // Kaç kez tıklandı

  // Hata bilgisi
  errorMessage  String?     @db.Text
  bounceType    String?     @db.VarChar(50) // "hard", "soft"

  // İlişkili kayıt
  orderId       String?     // Sipariş onayı gibi maillerde
  metadata      Json?       // Ek bilgi (coupon code, campaign ref vb.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([emailType])
  @@index([status])
  @@index([campaignId])
  @@index([tenantId, createdAt])
  @@index([trackingId])
  @@index([createdAt])
  @@map("email_logs")
}

/// Terk edilen sepet takibi — Kullanıcının sepetinde bırakıp gittiği ürünler
model AbandonedCart {
  id              String    @id @default(uuid())
  userId          String?   // Kayıtlı kullanıcı
  email           String?   @db.VarChar(255) // Bilinen e-posta

  // Sepet içeriği
  itemsJson       Json      // [{productId, name, quantity, unitPrice, imageUrl}]
  totalAmount     Decimal   @db.Decimal(14, 4)
  currency        String    @default("TRY") @db.VarChar(10)

  // Hatırlatma durumu
  reminder1SentAt DateTime? // 1 saat sonra gönderilen
  reminder2SentAt DateTime? // 24 saat sonra gönderilen
  couponCode      String?   @db.VarChar(50) // Gönderilen özel kupon kodu

  // Geri kazanım
  recoveredAt     DateTime? // Sepeti tamamlayarak sipariş verdi
  recoveredOrderId String?  @db.VarChar(100) // Tamamlanan siparişin ID'si
  recoveredAmount  Decimal? @db.Decimal(14, 4) // Kurtarılan ciro

  // Durum
  isRecovered     Boolean @default(false)
  isExpired       Boolean @default(false) // 7 gün sonra expired
  lastActivityAt  DateTime @default(now()) // Son sepet aktivitesi

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([email])
  @@index([isRecovered])
  @@index([lastActivityAt])
  @@index([reminder1SentAt])
  @@map("abandoned_carts")
}

// ═══════════════════════════════════════════════════════════════
// 📦 KURUMSAL STOK HAVUZU (ERP-Level Stock Pool Engine)
// ═══════════════════════════════════════════════════════════════

/// Stok Havuzu — Kodlar ürünlere doğrudan değil havuzlara eklenir.
/// Bir havuz birden fazla ürüne bağlanabilir (many-to-many).
/// Örn: 'PUBG UC Genel Havuz' → PUBG 60 UC, PUBG 325 UC
model StockPool {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(200)  // "PUBG UC Genel Havuz", "Steam TR Havuzu"
  description String?
  isActive    Boolean @default(true)

  // İlişkiler
  codes    EpinCode[]
  products StockPoolProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("stock_pools")
}

/// StockPool ↔ Product many-to-many bağlantı tablosu
model StockPoolProduct {
  id        String @id @default(uuid())
  poolId    String
  pool      StockPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([poolId, productId])
  @@index([productId])
  @@map("stock_pool_products")
}

/// ERP E-Pin Kodu — Her bir kod bağımsız maliyet, tedarikçi, öncelik ve kural taşır.
/// Sipariş anında akıllı dağıtım motoru bu tablodan seçim yapar.
model EpinCode {
  id        String    @id @default(uuid())
  poolId    String
  pool      StockPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  code          String    @unique @db.Text  // AES-256-GCM şifreli (ciphertext:iv:tag)
  codeHash      String?   @db.VarChar(64)  // SHA-256 hash (duplicate check için)
  addedByUserId String?   // Kodu sisteme ekleyen personel ID

  // Maliyet & Tedarikçi
  costPrice Decimal   @db.Decimal(12, 4) // Bu kodun geliş fiyatı
  currency  Currency  @default(USD)       // Maliyet para birimi
  supplier  String    @db.VarChar(200)    // Tedarikçi firma adı

  // Dağıtım kuralları
  priority        Int     @default(0)      // Yüksek = önce satılır (FIFO kırıcı)
  allowResellers  Boolean @default(true)   // false = Sadece B2C (bireysel müşteriye)

  // Kullanım durumu
  isUsed          Boolean   @default(false)
  usedAt          DateTime?
  usedByUserId    String?   // Hangi kullanıcıya satıldı
  usedByUser      User?     @relation("EpinCodeUser", fields: [usedByUserId], references: [id])
  orderId         String?   @db.VarChar(100) // Hangi siparişe atandı
  subOrderId      String?   @db.VarChar(100) // Hangi alt siparişe

  // Meta
  expiresAt       DateTime? // Kodun son kullanma tarihi (opsiyonel)
  batchId         String?   @db.VarChar(100) // Toplu ekleme grubu
  notes           String?   // Admin notu

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([poolId, isUsed, priority, createdAt])
  @@index([poolId, isUsed, allowResellers])
  @@index([orderId])
  @@index([usedByUserId])
  @@index([batchId])
  @@index([supplier])
  @@map("epin_codes")
}

// ─────────────────────────────────────────────────────────────
// DİNAMİK GÖREV SİSTEMİ (MISSIONS)
// ─────────────────────────────────────────────────────────────

enum MissionType {
  REFERRAL_COUNT   // X üye getir
  TOTAL_TURNOVER   // X TL ciro yap
  TOTAL_PROFIT     // X TL net kar ettir
  SOCIAL_SHARE     // Sosyal medyada paylaş (manuel onaylı)
  CUSTOM           // Özel görev (admin manuel)
}

enum MissionRewardType {
  CASH_BALANCE     // Cüzdan bakiyesi
  POINTS           // Sadakat puanı
  VIP_MEMBERSHIP   // VIP üyelik süresi
}

model Mission {
  id            String            @id @default(uuid())
  tenantIds     Json?
  title         String            @db.VarChar(200)
  description   String?
  imageUrl      String?           @db.VarChar(500)

  type          MissionType
  targetValue   Decimal           @db.Decimal(14, 4) // Hedef değer (50 üye, 10000 TL vb)

  rewardType    MissionRewardType
  rewardAmount  Decimal           @db.Decimal(12, 4) // Ödül tutarı (200 TL, 500 puan vb)

  isActive      Boolean           @default(true)
  startDate     DateTime?
  endDate       DateTime?

  // Kime açık?
  minTier       String?           @db.VarChar(100) // Min affiliate tier adı (null = herkese)

  progress      UserMissionProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("missions")
}

model UserMissionProgress {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionId     String
  mission       Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  currentValue  Decimal  @default(0) @db.Decimal(14, 4) // Mevcut ilerleme
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?
  rewardClaimed Boolean  @default(false)
  claimedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, missionId])
  @@index([userId, isCompleted])
  @@map("user_mission_progress")
}

// ═══════════════════════════════════════════════════════════════
// 🔐 ZERO-TRUST RBAC & GÜVENLİK SİSTEMİ
// ═══════════════════════════════════════════════════════════════

enum UnlockRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

/// Personel Rolü — yetki grupları
model StaffRole {
  id          String  @id @default(uuid())
  name        String  @unique @db.VarChar(100)  // "super_admin", "demo_admin", "operation_admin"
  displayName String  @db.VarChar(200)          // "Süper Admin"
  description String?
  color       String  @default("#6366f1") @db.VarChar(9)
  isSystem    Boolean @default(false)  // true = silinemez (seed rolleri)
  canDecryptWithoutApproval Boolean @default(false) // E-pin kodlarını onaysız görebilir

  permissions StaffRolePermission[]
  staff       StaffProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("staff_roles")
}

/// Rol ↔ Yetki bağlantısı (many-to-many)
model StaffRolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         StaffRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation("StaffRolePerms", fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("staff_role_permissions")
}

/// Personel Profili — User'a bağlı, hangi rolde olduğunu belirler
model StaffProfile {
  id       String    @id @default(uuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId   String
  role     StaffRole @relation(fields: [roleId], references: [id])

  // Ek bilgiler
  department  String?  @db.VarChar(100) // "Operasyon", "Finans", "Destek"
  phone       String?  @db.VarChar(20)
  isActive    Boolean  @default(true)
  lastActiveAt DateTime?

  // Unlock Request'ler
  unlockRequests EpinUnlockRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([isActive])
  @@map("staff_profiles")
}

/// E-pin Kod Çözme Talepleri — Zero-Trust workflow
/// Personel şifreli kodu görmek istediğinde onay mekanizması
model EpinUnlockRequest {
  id          String              @id @default(uuid())
  staffId     String
  staff       StaffProfile        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  epinCodeId  String
  status      UnlockRequestStatus @default(PENDING)

  // Onay/Red bilgisi
  reviewedById String?  // Onaylayan/Reddeden admin
  reviewedAt   DateTime?
  reviewNote   String?

  // Güvenlik metadata
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.VarChar(500)
  reason      String?  // Personelin talebi neden açtığına dair notu

  createdAt DateTime @default(now())
  expiresAt DateTime // Talep süresi (örn: 24 saat)

  @@index([staffId, status])
  @@index([status, createdAt])
  @@index([epinCodeId])
  @@map("epin_unlock_requests")
}
