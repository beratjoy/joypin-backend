/// Sipariş teslim, sepette ürün kaldı maili, stok alarm vb.
model NotificationTemplate {
  id      String @id @default(uuid())
  event   String @db.VarChar(50) // ORDER_CREATED, ORDER_DELIVERED, ABANDONED_CART, LOW_STOCK
  channel NotificationChannel

  subject String? @db.VarChar(300) // Email subject
  body    String  @db.Text         // Template body {{orderNumber}}, {{customerName}} vb.

  isActive Boolean @default(true)

  // Bayi grubu bazlı özelleştirme (#7 — her gruba ayrı mesaj)
  dealerGroupId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([event, channel, dealerGroupId])
  @@map("notification_templates")
}

// ─────────────────────────────────────────────────────────────
// 18. DÖNÜŞÜM TAKİP (#32 — Meta & Google ADS)
// ─────────────────────────────────────────────────────────────

model ConversionEvent {
  id        String @id @default(uuid())
  platform  String @db.VarChar(50)  // META, GOOGLE_ADS
  eventName String @db.VarChar(100) // Purchase, Lead, AddToCart

  orderId String?
  userId  String?

  value    Decimal? @db.Decimal(14, 4)
  currency Currency @default(USD)

  metadata Json?
  pixelId  String? @db.VarChar(100)

  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@index([platform])
  @@index([orderId])
  @@map("conversion_events")
}

// ─────────────────────────────────────────────────────────────
// 19. KATEGORİ BAZLI ÖDEME KISITLAMASI (#17)
// ─────────────────────────────────────────────────────────────

/// Belirli kategorilerde belirli ödeme yöntemlerini gizleme
model CategoryPaymentRestriction {
  id              String @id @default(uuid())
  categoryId      String
  paymentMethodId String
  isHidden        Boolean @default(true) // true = bu ödeme bu kategoride gizli

  category      ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod   @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([categoryId, paymentMethodId])
  @@map("category_payment_restrictions")
}

// ─────────────────────────────────────────────────────────────
// 20. KYC (BELGE DOĞRULAMA) SİSTEMİ
// ─────────────────────────────────────────────────────────────

/// KYC belge yükleme — Kripto/Stripe ve yüksek limitli bayiler için
model KycDocument {
  id            String @id @default(uuid())

  userId        String
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Belge bilgileri
  documentType  KycDocumentType
  documentUrl   String  @db.VarChar(500) // S3/Cloud Storage URL
  thumbnailUrl  String? @db.VarChar(500)

  // Metadata
  documentNumber String? @db.VarChar(50)  // Belge numarası (opsiyonel)
  issuedCountry  String? @db.VarChar(5)   // ISO ülke kodu
  issuedDate     DateTime?
  expiryDate     DateTime?

  // Doğrulama durumu
  status        KycStatus @default(PENDING_REVIEW)
  reviewedById  String?   // Admin ID
  reviewedAt    DateTime?
  reviewNotes   String?   @db.Text
  rejectionReason String? @db.Text

  // OCR/AI oto-doğrulama (opsiyonel)
  ocrData       Json?     // Otomatik okunan veriler
  matchScore    Int?      // 0-100 eşleşme skoru

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([documentType])
  @@map("kyc_documents")
}

// ═══════════════════════════════════════════════════════════════
// 21. GLOBAL ÖDEME GEÇİTLERİ & FİNANS MODÜLLERİ
// ═══════════════════════════════════════════════════════════════

enum PaymentGateway {
  STRIPE
  MERCURY
  BINANCE_PAY
  CRYPTOMUS
  BANK_TRANSFER
  WALLET
}

enum PaymentTransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
}

enum WithdrawalMethod {
  CRYPTO_USDT_TRC20
  CRYPTO_USDT_ERC20
  CRYPTO_BTC
  BANK_WIRE
  WISE
  PAYONEER
}

enum NotificationType {
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  WITHDRAWAL_STATUS_CHANGE
  ORDER_STATUS_CHANGE
  WALLET_BALANCE_CHANGE
  SYSTEM_ANNOUNCEMENT
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

/// Ana şirket/şirketler (Billing Entity)
model BillingEntity {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(200)
  legalName   String  @db.VarChar(300) // Joy Bilişim Yazılım...
  taxId       String  @db.VarChar(50)   // Vergi numarası
  vatNumber   String? @db.VarChar(50)   // KDV/VAT numarası
  
  // Adres bilgileri
  address     String
  city        String  @db.VarChar(100)
  state       String? @db.VarChar(100)
  country     String  @db.VarChar(50)   // ISO ülke kodu
  postalCode  String  @db.VarChar(20)
  
  // İletişim
  email       String  @db.VarChar(255)
  phone       String  @db.VarChar(30)
  website     String? @db.VarChar(200)
  
  // Banka/Kripto hesap bilgileri (JSON)
  paymentAccounts Json?
  
  // Şirket logosu/imza
  logoUrl     String? @db.VarChar(500)
  stampUrl    String? @db.VarChar(500)
  
  isActive    Boolean @default(true)
  isDefault   Boolean @default(false) // Varsayılan fatura şirketi
  
  invoices    Invoice[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("billing_entities")
}

/// Detaylı ödeme işlem kaydı (Gateway entegrasyonları için)
model PaymentTransaction {
  id              String @id @default(uuid())
  tenantId        String?
  
  // İlişkiler
  userId          String
  user            User   @relation(fields: [userId], references: [id])
  orderId         String?
  order           Order? @relation(fields: [orderId], references: [id])
  walletTxId      String?  @unique
  walletTx        WalletTransaction? @relation(fields: [walletTxId], references: [id])
  
  // Ödeme bilgileri
  gateway         PaymentGateway
  amount          Decimal @db.Decimal(14, 4)
  currency        Currency @default(USD)
  feeAmount       Decimal @default(0) @db.Decimal(14, 4) // İşlem komisyonu
  netAmount       Decimal @db.Decimal(14, 4) // Komisyon düşülmüş tutar
  
  // Gateway'den dönen bilgiler
  gatewayTransactionId String? @db.VarChar(255)
  gatewayResponse      Json?   // Ham gateway yanıtı
  
  // Durum
  status          PaymentTransactionStatus @default(PENDING)
  failureReason   String? @db.Text
  
  // Kripto özel alanları
  cryptoCurrency  String? @db.VarChar(10)  // BTC, USDT, vb.
  cryptoAddress   String? @db.VarChar(100) // Ödeme adresi
  cryptoTxHash    String? @db.VarChar(100) // Blockchain tx hash
  
  // 3D Secure / Fraud kontrolü
  riskScore       Int?    // 0-100 fraud skoru
  is3DSecure      Boolean @default(false)
  
  // Zaman damgaları
  initiatedAt     DateTime @default(now())
  completedAt     DateTime?
  
  @@index([userId])
  @@index([orderId])
  @@index([tenantId])
  @@index([gateway])
  @@index([status])
  @@map("payment_transactions")
}

/// Para çekme talepleri (Bayiler için)
model WithdrawalRequest {
  id              String @id @default(uuid())
  
  userId          String
  user            User   @relation(fields: [userId], references: [id])
  
  // Talep bilgileri
  amount          Decimal @db.Decimal(14, 4)
  currency        Currency @default(USD)
  feeAmount       Decimal @default(0) @db.Decimal(14, 4)
  netAmount       Decimal @db.Decimal(14, 4)
  
  // Çekim yöntemi
  method          WithdrawalMethod
  
  // Hedef hesap bilgileri (şifreli olarak saklanır)
  destinationAccount Json // { address: "0x...", network: "TRC20" } veya { iban: "...", swift: "..." }
  
  // Durum takibi
  status          WithdrawalStatus @default(PENDING)
  statusHistory   Json? // [{ status: "PENDING", at: "...", by: "...", note: "..." }]
  
  // İnceleme
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String? @db.Text
  
  // İşlem
  processedAt     DateTime?
  processedTxHash String? @db.VarChar(100) // Blockchain tx hash veya banka referans
  
  // Hata durumunda
  failureReason   String? @db.Text
  retryCount      Int     @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("withdrawal_requests")
}

/// Ürün bazlı bayi iskontoları (PUBG, MLBB, Roblox için)
model ProductDiscount {
  id              String @id @default(uuid())
  
  // İlişkiler
  dealerGroupId   String
  dealerGroup   DealerGroup @relation(fields: [dealerGroupId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  // İskonto kuralları
  discountPercent Decimal @db.Decimal(5, 2) // %0-100 arası
  discountAmount  Decimal? @db.Decimal(14, 4) // Sabit tutar indirim (opsiyonel)
  
  // Minimum/maximum sipariş koşulları
  minQuantity     Int @default(1)
  maxQuantity     Int @default(0) // 0 = sınırsız
  minOrderAmount  Decimal @default(0) @db.Decimal(14, 4)
  
  // Geçerlilik
  validFrom       DateTime?
  validUntil      DateTime?
  
  isActive        Boolean @default(true)
  priority        Int     @default(0) // Çakışan iskontolarda öncelik
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([dealerGroupId, productId])
  @@index([productId])
  @@index([isActive])
  @@map("product_discounts")
}

/// Kullanıcı bildirimleri (WebSocket/Polling destekli)
model UserNotification {
  id              String @id @default(uuid())
  
  userId          String
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Bildirim içeriği
  type            NotificationType
  title           String  @db.VarChar(200)
  message         String  @db.Text
  
  // İlişkili kayıt (opsiyonel)
  relatedEntityType String? @db.VarChar(50) // "order", "withdrawal", "payment"
  relatedEntityId   String?
  
  // İçerik zenginleştirme
  actionUrl       String? @db.VarChar(500) // Tıklanınca yönlendirilecek URL
  actionText      String? @db.VarChar(100) // Buton metni ("Siparişi Gör", "İncele")
  imageUrl        String? @db.VarChar(500)
  
  // Dağıtım durumu
  deliveryStatus  NotificationDeliveryStatus @default(PENDING)
  
  // Okundu bilgisi
  isRead          Boolean @default(false)
  readAt          DateTime?
  
  // WebSocket/Polling için timestamp
  createdAt       DateTime @default(now())
  expiresAt       DateTime? // Otomatik silinecek tarih
  
  @@index([userId])
  @@index([type])
  @@index([deliveryStatus])
  @@index([isRead])
  @@index([createdAt])
  @@map("user_notifications")
}


// ═══════════════════════════════════════════════════════════════
// SMART PAYMENT ROUTING & TICKET SYSTEM (v8)
// ═══════════════════════════════════════════════════════════════

enum PaymentProvider {
  STRIPE       // Global — Kart ödemeleri (USD, EUR, GBP)
  CRYPTOMUS    // Global — Kripto ödemeleri (tüm para birimleri)
  PAYTR        // Türkiye — Yerel kart/havale (TRY)
  LIDIO        // Türkiye — Yerel alternatif ödeme (TRY)
}

enum TicketStatus {
  OPEN
  AWAITING_REPLY
  REPLIED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model PaymentWebhookLog {
  id            String          @id @default(uuid())
  tenantId      String?
  provider      PaymentProvider
  eventType     String          @db.VarChar(100)
  rawPayload    Json
  signature     String?         @db.Text
  isValid       Boolean         @default(false)
  processedAt   DateTime?
  errorMessage  String?         @db.Text
  orderId       String?
  createdAt     DateTime        @default(now())

  @@index([provider, createdAt])
  @@index([orderId])
  @@index([tenantId])
  @@map("payment_webhook_logs")
}

model Ticket {
  id           String         @id @default(uuid())
  tenantId     String?
  userId       String
  orderId      String?        // Sipariş referansı (opsiyonel)
  subject      String         @db.VarChar(255)
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  assignedToId String?        // Support personel

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  resolvedAt   DateTime?
  closedAt     DateTime?

  messages     TicketMessage[]

  @@index([userId, status])
  @@index([assignedToId, status])
  @@index([orderId])
  @@index([tenantId])
  @@map("tickets")
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  senderId   String   // Kullanıcı veya support personel
  isStaff    Boolean  @default(false)
  content    String   @db.Text
  attachments Json?   // File URLs array

  createdAt  DateTime @default(now())

  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

// ─────────────────────────────────────────────────────────────
// SITE SETTINGS & SLIDER (CMS)
// ─────────────────────────────────────────────────────────────

model SiteSettings {
  id          String  @id @default(uuid())
  key         String  @unique @db.VarChar(100)  // "site_title", "seo_description", "footer_text" vb.
  value       String  @db.Text
  group       String  @default("general") @db.VarChar(50) // general, seo, footer, social
  description String? @db.VarChar(255)

  updatedAt DateTime @updatedAt
  updatedBy String?  // Admin userId

  @@index([group])
  @@map("site_settings")
}

model TenantBrand {
  id              String  @id @default(uuid())
  name            String  @db.VarChar(120)
  slug            String  @unique @db.VarChar(120)
  publicName      String  @db.VarChar(160)
  defaultLocale   String  @default("tr") @db.VarChar(10)
  defaultCountry  String  @default("TR") @db.VarChar(10)
  defaultCurrency Currency @default(TRY)
  primaryColor    String  @default("#6366f1") @db.VarChar(20)
  accentColor     String  @default("#22c55e") @db.VarChar(20)
  logoUrl         String? @db.VarChar(500)
  faviconUrl      String? @db.VarChar(500)
  cdnPublicUrl    String? @db.VarChar(500)
  isDefault       Boolean @default(false)
  isActive        Boolean @default(true)
  metadata        Json?

  domains  TenantDomain[]
  settings TenantSetting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDefault])
  @@index([isActive])
  @@map("tenant_brands")
}

model TenantDomain {
  id        String      @id @default(uuid())
  tenantId  String
  tenant    TenantBrand @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostname  String      @unique @db.VarChar(255)
  isPrimary Boolean     @default(false)
  isActive  Boolean     @default(true)
  notes     String?     @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([hostname, isActive])
  @@map("tenant_domains")
}

model TenantSetting {
  id          String      @id @default(uuid())
  tenantId    String
  tenant      TenantBrand @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String      @db.VarChar(100)
  value       String      @db.Text
  group       String      @default("general") @db.VarChar(50)
  description String?     @db.VarChar(255)
  updatedBy   String?

  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, group])
  @@map("tenant_settings")
}

// ─────────────────────────────────────────────────────────────
// GAMIFICATION: LOOT BOX (Kasa Açma)
// ─────────────────────────────────────────────────────────────

enum LootBoxRewardType {
  POINT    // Sadakat puanı
  BALANCE  // Cüzdan bakiyesi
}

model LootBox {
  id           String   @id @default(uuid())
  tenantIds    Json?
  name         String   @db.VarChar(200) // "Altın Kasa", "Elmas Kutu"
  description  String?
  imageUrl     String?  @db.VarChar(500)
  price        Decimal  @db.Decimal(12, 4) // Bakiye veya Puan fiyatı
  isPointPrice Boolean  @default(false)    // true = puanla alınır, false = bakiye ile
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)

  rewards LootBoxReward[]
  opens   LootBoxOpen[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loot_boxes")
}

model LootBoxReward {
  id                   String             @id @default(uuid())
  boxId                String
  box                  LootBox            @relation(fields: [boxId], references: [id], onDelete: Cascade)

  rewardType           LootBoxRewardType  // POINT veya BALANCE
  rewardValue          Decimal            @db.Decimal(12, 4) // 50 puan, 10 TL vb.
  rewardLabel          String?            @db.VarChar(100)   // "50 Puan!", "25 TL Bonus"
  dropChancePercentage Decimal            @db.Decimal(5, 2)  // 0.01 - 100.00 arası

  createdAt DateTime @default(now())

  @@index([boxId])
  @@map("loot_box_rewards")
}

model LootBoxOpen {
  id       String  @id @default(uuid())
  boxId    String
  box      LootBox @relation(fields: [boxId], references: [id], onDelete: Cascade)
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  rewardType  LootBoxRewardType
  rewardValue Decimal @db.Decimal(12, 4)
  rewardLabel String? @db.VarChar(100)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([boxId])
  @@map("loot_box_opens")
}

// ─────────────────────────────────────────────────────────────
// GAMIFICATION: USER COUPON (Kişiye Özel Kupon Tanımlama)
// ─────────────────────────────────────────────────────────────

model UserCoupon {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  couponId String
  coupon   DiscountCoupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  isUsed   Boolean   @default(false)
  usedAt   DateTime?
  expiresAt DateTime?

  assignedReason String? @db.VarChar(200) // "Hoşgeldin kampanyası", "Terk edilen sepet"

  createdAt DateTime @default(now())

  @@unique([userId, couponId])
  @@index([userId, isUsed])
  @@map("user_coupons")
