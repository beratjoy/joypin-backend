// ═══════════════════════════════════════════════════════════════
// E-Pin & Top-Up Platform — Prisma Schema
// Base Currency: USD  |  DB: PostgreSQL
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT     // Destek personeli — e-pin şifrelerini GÖREMEZ
  STAFF
  RESELLER    // Bayi (Dealer alias)
  DEALER
  CUSTOMER
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum KycDocumentType {
  IDENTITY_CARD
  PASSPORT
  DRIVING_LICENSE
  TAX_CERTIFICATE
  COMPANY_REGISTRATION
  UTILITY_BILL
  SELFIE_WITH_ID
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum PricingModel {
  COST_PLUS_MARGIN
  FIXED_MINUS_DISCOUNT
  FIXED_PRICE
}

enum StockType {
  EPIN
  API_TOPUP
}

enum ProductType {
  EPIN   // Hazır kod stoktan verilir
  TOPUP  // Manuel yükleme (admin/bot), müşteriden ekstra bilgi alınır
}

enum Currency {
  USD
  EUR
  TRY
  GBP
  AED
  SAR
}

enum EPinStatus {
  AVAILABLE
  RESERVED
  SOLD
  EXPIRED
  DEFECTIVE
}

enum ParentOrderStatus {
  PENDING
  PROCESSING
  PARTIALLY_DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum SubOrderStatus {
  PENDING
  PROCESSING
  PARTIALLY_DELIVERED
  DELIVERED
  CANCELLED
  REFUNDED
  FAILED
  AWAITING_FALLBACK
  PENDING_STOCK                // EPIN stokta yok, admin kod girişi bekleniyor
  PENDING_TOPUP                // TOPUP ürünü, admin manuel yükleme yapacak
  MANUAL_INTERVENTION_REQUIRED // Hiçbir sağlayıcı başarılı olamadı, admin müdahale gerekli
}

enum DeliveryType {
  EPIN
  API_TOPUP
  MANUAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum WalletTxType {
  CREDIT
  DEBIT
  TRANSFER
  FREEZE
  UNFREEZE
}

enum BalanceField {
  CURRENT
  BONUS
  WITHDRAWABLE
  CREDIT
  FROZEN
  LOTTERY
  CASHBACK
  COMMISSION
}

enum ReferralBasis {
  PROFIT
  SALE_PRICE
}

enum BotProviderType {
  API
  BOT
  MANUAL
}

enum BotProviderStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum AuditAction {
  ACTIVITY
  PAGE_VIEW
  CREATE
  UPDATE
  DELETE
  VIEW_EPIN
  DECRYPT_EPIN
  LOGIN
  LOGOUT
  ORDER_PLACED
  ORDER_CANCELLED
  ORDER_REFUNDED
  SUBORDER_CANCELLED
  SUBORDER_DELIVERED
  SUBORDER_REFUNDED
  BALANCE_UPDATED
  REFERRAL_PAID
  STAFF_CLAIM_ORDER
  STAFF_RELEASE_ORDER
  API_FALLBACK_TRIGGERED
  GUEST_ORDER_CREATED
  COUPON_APPLIED
  INVOICE_ISSUED
  SESSION_IMPERSONATED
}

enum CustomerType {
  INDIVIDUAL   // Bireysel
  CORPORATE    // Kurumsal
}

enum InvoiceType {
  DEFAULT            // Varsayılan
  E_INVOICE          // E-Fatura (BirFatura entegre)
  PDF_INTERNATIONAL  // Yurt dışı PDF fatura
}

enum InvoiceStatus {
  DRAFT
  PENDING
  ISSUED
  CANCELLED
}

enum ReferralIncomeModel {
  PRODUCT_SALE      // Ürün Satışı
  NEW_REGISTRATION  // Yeni Üye Kaydı
}

enum ReferralModelType {
  REFERRAL_LINK  // Referans linki ile
  LIST_INCOME    // Liste geliri (üye satın almalarından)
}

enum ReferralCalculation {
  SALE_PRICE           // Satış fiyatından
  PROFIT_STOCK_COST    // Kâr — Stok Maliyeti
  PROFIT_CURRENT_COST  // Kâr — Güncel Maliyet
}

enum CouponType {
  PERCENTAGE    // Yüzde indirim
  FIXED_AMOUNT  // Sabit tutar indirim
}

enum CouponStatus {
  ACTIVE
  EXPIRED
  DEPLETED
  DISABLED
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

// ─────────────────────────────────────────────────────────────
// 1. USER & ROLE & PERMISSION
// ─────────────────────────────────────────────────────────────

model User {
  id             String     @id @default(uuid())
  firstName      String     @db.VarChar(100)
  lastName       String     @db.VarChar(100)
  email          String     @unique @db.VarChar(255)
  passwordHash   String     @db.VarChar(255)
  phone          String?    @db.VarChar(20)
  role           UserRole   @default(CUSTOMER)
  status         UserStatus @default(PENDING_VERIFICATION)

  // Müşteri Detayları (Image 5 — Müşteri Bilgileri)
  customerType     CustomerType @default(INDIVIDUAL)
  identityNumber   String?      @db.VarChar(20)   // TC Kimlik No
  birthDate        DateTime?
  taxExempt        Boolean      @default(false)   // Vergi Muafiyeti
  invoiceType      InvoiceType  @default(DEFAULT)  // Fatura Tipi

  // Üye Tipi (B2B kademe fiyatlandırma)
  memberTypeId   String?
  memberType     MemberType?   @relation(fields: [memberTypeId], references: [id])

  // Bayi ilişkisi
  dealerGroupId  String?
  dealerGroup    DealerGroup?  @relation(fields: [dealerGroupId], references: [id])

  // Referans sistemi
  referredById   String?
  referredBy     User?         @relation("UserReferrals", fields: [referredById], references: [id])
  referrals      User[]        @relation("UserReferrals")
  referralCode   String?       @unique @db.VarChar(20)

  // Doğrulama Durumu (Image 5)
  smsVerified      Boolean @default(false)
  emailVerified    Boolean @default(false)

  // OTP Ayarları (Giriş OTP / Sipariş OTP ayrımı)
  otpSecret        String?  @db.VarChar(255)
  loginOtpEnabled  Boolean  @default(false)  // Giriş OTP
  orderOtpEnabled  Boolean  @default(false)  // Sipariş OTP

  // Ticari İletişim Tercihleri (Image 5)
  smsNotification   Boolean @default(true)
  emailNotification Boolean @default(true)
  callNotification  Boolean @default(true)

  // KYC Durumu
  kycStatus        KycStatus @default(NOT_SUBMITTED)
  kycApprovedAt    DateTime?
  kycLevel         Int       @default(0) // 0=Yok, 1=Temel, 2=Gelişmiş, 3=Kurumsal

  // Sadakat Puanı
  pointsBalance     Int      @default(0) // Sadakat puanı bakiyesi
  extraLootboxRights Int     @default(0)

  // Metadata
  countryCode       String  @default("TR") @db.VarChar(10)
  preferredCurrency Currency @default(TRY)
  lastLoginAt       DateTime?
  lastLoginIp       String?  @db.VarChar(45)

  // İzinler (Staff için granüler yetki)
  permissions    UserPermission[]

  // İlişkiler
  orders         Order[]
  wallet         Wallet?
  invoices       Invoice[]
  kycDocuments   KycDocument[]
  referralLinks  UserReferral[]   @relation("ReferrerLinks")
  referredLinks  UserReferral[]   @relation("ReferredLinks")
  auditLogs      AuditLog[]
  walletTxPerformed WalletTransaction[] @relation("PerformedBy")
  withdrawalRequests  WithdrawalRequest[]
  notifications       UserNotification[]
  paymentTransactions PaymentTransaction[]
  userCoupons         UserCoupon[]
  productReviews      ProductReview[]
  lootBoxOpens        LootBoxOpen[]
  subscriptions       UserSubscription[]
  affiliateEarnings   AffiliateTransaction[] @relation("AffiliateEarner")
  missionProgress     UserMissionProgress[]
  epinCodesUsed       EpinCode[] @relation("EpinCodeUser")
  staffProfile        StaffProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberTypeId])
  @@index([dealerGroupId])
  @@index([referredById])
  @@index([role, status])
  @@map("users")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(100) // ör: "epin.decrypt", "order.cancel"
  name        String   @db.VarChar(150)
  description String?
  module      String   @db.VarChar(50)          // ör: "products", "orders", "epins"

  users       UserPermission[]
  staffRoles  StaffRolePermission[] @relation("StaffRolePerms")

  createdAt DateTime @default(now())

  @@index([module])
  @@map("permissions")
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  grantedAt DateTime @default(now())
  grantedBy String?  // Admin UUID who granted

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ─────────────────────────────────────────────────────────────
// 2. DEALER GROUP
// ─────────────────────────────────────────────────────────────

model DealerGroup {
  id                    String  @id @default(uuid())
  name                  String  @unique @db.VarChar(100)
  description           String?
  defaultDiscountPercent Decimal @default(0) @db.Decimal(5, 2)
  minOrderAmount        Decimal @default(0) @db.Decimal(12, 2)
  creditLimit           Decimal @default(0) @db.Decimal(12, 2)
  isActive              Boolean @default(true)

  // API iptal politikası: API iptal olduğunda müşteriye de iptal et
  cancelOnApiFail       Boolean @default(false)

  users                 User[]
  pricings              DealerGroupPricing[]
  allowedPaymentMethods DealerGroupPaymentMethod[]
  stockRestrictions     DealerStockRestriction[]
  apiPriorities         DealerApiPriority[]
  productDiscounts      ProductDiscount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dealer_groups")
}

/// Bayilere özel stok kapatma: belirli ürünler bayi grubuna kapatılabilir
model DealerStockRestriction {
  id            String      @id @default(uuid())
  dealerGroupId String
  productId     String
  isBlocked     Boolean     @default(true) // true = bu ürün bu gruba kapalı

  dealerGroup   DealerGroup @relation(fields: [dealerGroupId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([dealerGroupId, productId])
  @@map("dealer_stock_restrictions")
}

/// Bayilere özel API önceliği: hangi BotProvider öncelikli kullanılacak
model DealerApiPriority {
  id            String      @id @default(uuid())
  dealerGroupId String
  productId     String
  botProviderId String
  priority      Int         @default(0) // düşük = yüksek öncelik

  dealerGroup   DealerGroup @relation(fields: [dealerGroupId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  botProvider   BotProvider @relation(fields: [botProviderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([dealerGroupId, productId, botProviderId])
  @@map("dealer_api_priorities")
}

// ─────────────────────────────────────────────────────────────
// 3. PRODUCT & PRICING
// ─────────────────────────────────────────────────────────────

model ProductCategory {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(100)
  slug        String  @unique @db.VarChar(120)
  description String?
  imageUrl    String? @db.VarChar(500)
  logoUrl     String? @db.VarChar(500)
  layout      String  @default("jollymax") @db.VarChar(50)
  badges      Json?
  paymentMethods Json?
  allowedCountries Json?
  tenantIds Json?
  requiresUserId Boolean @default(false)
  userIdLabel String? @db.VarChar(100)
  userIdPlaceholder String? @db.VarChar(200)
  zoneIdLabel String? @db.VarChar(100)

  parentId    String?
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryTree")

  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  // SEO
  seoTitle       String? @db.VarChar(200)
  seoDescription String? @db.VarChar(500)

  products    Product[]
  paymentRestrictions CategoryPaymentRestriction[]
  reviews     ProductReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_categories")
}

enum ProductReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProductReview {
  id              String              @id @default(uuid())
  userId          String?
  user            User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  productId       String?
  product         Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  categoryId      String?
  category        ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderId         String?
  order           Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customerName    String              @db.VarChar(120)
  customerAvatar  String?             @db.VarChar(10)
  gameName        String?             @db.VarChar(160)
  rating          Int                 @default(5)
  comment         String              @db.Text
  status          ProductReviewStatus @default(PENDING)
  isFake          Boolean             @default(false)
  isFeatured      Boolean             @default(false)
  reviewedAt      DateTime            @default(now())
  approvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([productId])
  @@index([categoryId])
  @@index([orderId])
  @@map("product_reviews")
}

model Product {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(200)
  shortName   String? @db.VarChar(120)
  slug        String  @unique @db.VarChar(220)
  description String?
  sliderImageUrl     String? @db.VarChar(500)  // Ana sayfa/slider gorseli
  iconUrl            String? @db.VarChar(500)  // Site kartı ikonu (128×128)
  merchantImageUrl   String? @db.VarChar(500)  // Merchant resmi (yüksek çözünürlük)

  // Kategori
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id])

  // Fiyatlandırma (USD bazlı)
  baseCurrency    Currency     @default(USD)
  baseCost        Decimal      @db.Decimal(12, 4)        // Maliyet USD
  pricingModel    PricingModel @default(COST_PLUS_MARGIN)
  marginPercent   Decimal      @default(0) @db.Decimal(5, 2)  // COST_PLUS_MARGIN
  fixedPrice      Decimal      @default(0) @db.Decimal(12, 4) // FIXED_MINUS_DISCOUNT
  discountPercent Decimal      @default(0) @db.Decimal(5, 2)  // FIXED_MINUS_DISCOUNT

  // Ürün Tipi
  type              ProductType @default(EPIN)

  // Stok
  stockType         StockType @default(EPIN)
  hasInfiniteStock  Boolean   @default(false) // true = stok sayısı sorgulanmaz
  stockCount        Int       @default(0)     // hasInfiniteStock=false ise AVAILABLE epin adedi
  lowStockThreshold Int       @default(10)

  // Puan Marketi fiyatı (null = puan ile satılamaz)
  pointPrice        Int?     // Kaç puan karşılığı alınabilir

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  allowedCountries Json?
  tenantIds Json?
  metadata  Json?   // bölge, platform vb.

  // SEO (madde #30 — toplu SEO ayarı, flat URL: /pubg — #33)
  seoTitle       String? @db.VarChar(200)
  seoDescription String? @db.VarChar(500)
  seoKeywords    String? @db.VarChar(500)

  // Topup ürünleri için müşteriden alınacak bilgi alanları (#2)
  // [{key:"gameId", label:"Oyun ID", required:true, type:"text"}, ...]
  customInputFields Json?

  // İlişkiler
  dealerGroupPricings  DealerGroupPricing[]
  epins                EPin[]
  subOrders            SubOrder[]
  botProviderProducts  BotProviderProduct[]
  stockRestrictions    DealerStockRestriction[]
  apiPriorities        DealerApiPriority[]
  discounts            ProductDiscount[]
  prices               ProductPrice[]
  topupFields          TopupField[]
  reviews              ProductReview[]
  epinStocks           EpinStock[]
  productProviders     ProductProvider[]
  stockPoolProducts    StockPoolProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([stockType, isActive])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────
// ÜYE TİPİ & KADEME FİYATLANDIRMA (B2B)
// ─────────────────────────────────────────────────────────────

model MemberType {
  id         String  @id @default(uuid())
  name       String  @unique @db.VarChar(100) // Bireysel, Gold, Platin, Royal Bayi vb.
  colorCode  String  @default("#6366f1") @db.VarChar(9) // Badge rengi
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  // Varsayılan indirim oranı (bu tipe atananlara genel indirim)
  defaultDiscountPercent Decimal @default(0) @db.Decimal(5, 2)

  users              User[]
  prices             ProductPrice[]
  subscriptionPlans  SubscriptionPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("member_types")
}

model ProductPrice {
  id           String     @id @default(uuid())
  productId    String
  memberTypeId String
  price        Decimal    @db.Decimal(12, 4) // Bu üye tipine özel satış fiyatı
  currency     Currency   @default(TRY)
  isActive     Boolean    @default(true)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  memberType MemberType @relation(fields: [memberTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, memberTypeId])
  @@index([memberTypeId])
  @@map("product_prices")
}

// ─────────────────────────────────────────────────────────────
// TOPUP FIELD (Müşteriden istenen bilgi alanları)
// ─────────────────────────────────────────────────────────────

/// TOPUP ürünleri için müşteriden alınacak form alanlarını tanımlar
/// Örn: "Player ID", "Server ID", "Nickname"
model TopupField {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  fieldKey    String  @db.VarChar(50)   // "playerId", "serverId"
  fieldLabel  String  @db.VarChar(100)  // "Oyuncu ID'nizi Girin"
  fieldType   String  @default("text") @db.VarChar(20) // text, number, select
  placeholder String? @db.VarChar(200)
  isRequired  Boolean @default(true)
  sortOrder   Int     @default(0)
  options     Json?   // select tipi için: ["Server 1","Server 2"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("topup_fields")
}

// ─────────────────────────────────────────────────────────────
// EPIN STOCK (Basit hazır kod stoku — düz metin)
// ─────────────────────────────────────────────────────────────

/// EPIN ürünleri için admin tarafından toplu eklenen kodlar.
/// Sipariş geldiğinde kullanılmamış kod otomatik atanır.
model EpinStock {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  code      String  @db.Text          // E-pin kodu (düz metin)
  isUsed    Boolean @default(false)
  orderId   String? @db.VarChar(100)  // Hangi siparişe atandı
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([productId, isUsed])
  @@index([orderId])
  @@map("epin_stocks")
}

model DealerGroupPricing {
  id            String  @id @default(uuid())
  dealerGroupId String
  productId     String

  overridePricingModel PricingModel?
  customMarginPercent  Decimal?  @db.Decimal(5, 2)
  customFixedPrice     Decimal?  @db.Decimal(12, 4)
  customDiscountPercent Decimal? @db.Decimal(5, 2)
  isActive             Boolean   @default(true)

  dealerGroup DealerGroup @relation(fields: [dealerGroupId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealerGroupId, productId])
  @@map("dealer_group_pricings")
}

model ExchangeRate {
  id           String   @id @default(uuid())
  fromCurrency Currency
  toCurrency   Currency
  rate         Decimal  @db.Decimal(18, 8)
  rawRate      Decimal? @db.Decimal(18, 8)
  spreadPercent Decimal @default(0) @db.Decimal(5, 2)
  source       String?  @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromCurrency, toCurrency])
  @@index([fromCurrency])
  @@index([toCurrency])
  @@map("exchange_rates")
}

// ─────────────────────────────────────────────────────────────
// 4. E-PIN (Şifreli Saklama)
// ─────────────────────────────────────────────────────────────

model EPin {
  id            String     @id @default(uuid())
  productId     String
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  encryptedCode String     @db.Text          // AES-256-CBC şifreli
  encryptionIv  String     @db.VarChar(64)   // Pin'e özel IV
  status        EPinStatus @default(AVAILABLE)

  // Tedarikçi & Muhasebe (zorunlu)
  supplierId    String
  supplier      Supplier   @relation(fields: [supplierId], references: [id])
  purchaseCost  Decimal    @db.Decimal(12, 4) // Alış maliyeti
  purchaseCurrency Currency @default(USD)

  expiresAt     DateTime?
  serialNumber  String?    @db.VarChar(100)
  batchId       String?    @db.VarChar(100)
  supplierRef   String?    @db.VarChar(100)

  reservedAt    DateTime?
  soldAt        DateTime?

  // Teslimat ilişkisi
  subOrderItem  SubOrderItem?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, status])
  @@index([batchId])
  @@index([supplierId])
  @@map("epins")
}

// ─────────────────────────────────────────────────────────────
// 5. ORDERS (Parent → Sub → Item)
// ─────────────────────────────────────────────────────────────

model Order {
  id          String @id @default(uuid())
  orderNumber String @unique @db.VarChar(30)
  tenantId    String?

  // Kullanıcı ilişkisi (kayıtlı veya misafir)
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Misafir Alışverişi (Guest Checkout)
  isGuest            Boolean  @default(false)
  guestEmail         String?  @db.VarChar(255)
  guestPhone         String?  @db.VarChar(20)
  guestTrackingToken String?  @unique @db.VarChar(64) // güvenli takip tokeni

  currency    Currency          @default(TRY)
  totalAmount Decimal           @default(0) @db.Decimal(14, 4)
  netAmount   Decimal           @default(0) @db.Decimal(14, 4)

  status        ParentOrderStatus @default(PENDING)
  paymentStatus PaymentStatus     @default(PENDING)
  paymentMethod String?           @db.VarChar(50)
  paymentRef    String?           @db.VarChar(200)

  customerNote String?
  adminNote    String?
  ipAddress    String? @db.VarChar(45)

  // Personel Sipariş Havuzu (Staff Pool)
  assignedStaffId String?          // Siparisi devralan personel
  staffLockedAt   DateTime?        // Kilitleme zamanı
  staffNote       String?          // Personel notu

  subOrders            SubOrder[]
  walletTransactions   WalletTransaction[]
  referralTransactions ReferralTransaction[]
  financialLogs        OrderFinancialLog[]
  paymentTxs           PaymentTransaction[]
  reviews              ProductReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([guestTrackingToken])
  @@index([assignedStaffId])
  @@index([tenantId])
  @@map("orders")
}

model SubOrder {
  id            String @id @default(uuid())
  parentOrderId String
  parentOrder   Order  @relation(fields: [parentOrderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(12, 4)
  unitCost   Decimal @db.Decimal(12, 4)
  totalPrice Decimal @db.Decimal(14, 4)
  currency   Currency @default(TRY)

  status        SubOrderStatus @default(PENDING)
  deliveryType  DeliveryType   @default(EPIN)
  deliveredCount Int           @default(0)

  // Müşteriden alınan bilgiler (TOPUP ürünleri için)
  topupFieldData   Json?  // {"playerId":"12345","serverId":"2"}

  // Bot / API Fallback
  botProviderId    String?
  botProvider      BotProvider? @relation(fields: [botProviderId], references: [id])
  fallbackAttempts Int          @default(0)
  lastError        String?

  // Personel notları
  adminNote     String?
  cancelReason  String?   // İptal sebebi (personel girer)
  deliveryNote  String?   // Teslimat notu (personel girer)

  items SubOrderItem[]
  referralTransactions ReferralTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentOrderId])
  @@index([status])
  @@map("sub_orders")
}

model SubOrderItem {
  id         String   @id @default(uuid())
  subOrderId String
  subOrder   SubOrder @relation(fields: [subOrderId], references: [id], onDelete: Cascade)

  epinId      String?  @unique
  epin        EPin?    @relation(fields: [epinId], references: [id])
  externalRef String?  @db.VarChar(200)

  isDelivered  Boolean   @default(false)
  deliveredAt  DateTime?
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([subOrderId])
  @@map("sub_order_items")
}

// ─────────────────────────────────────────────────────────────
// 5b. ORDER FINANCIAL LOG (Muhasebe — parçalı iptal/iade kaydı)
// ─────────────────────────────────────────────────────────────

enum FinancialLogType {
  SALE                 // Satış gerçekleşti
  PARTIAL_REFUND       // Parçalı iade
  FULL_REFUND          // Tam iade
  CANCELLATION         // İptal
  SERVICE_FEE          // Hizmet bedeli
  TAX                  // Vergi
  COMMISSION_REVERSAL  // Komisyon geri alma
}

/// Her finansal hareket immutable kayıt olarak tutulur.
/// Parçalı iptallerde bile hangi SubOrder için ne kadar iade yapıldığı net izlenebilir.
model OrderFinancialLog {
  id         String           @id @default(uuid())
  orderId    String
  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  subOrderId String?          // Hangi alt siparişle ilgili (null = parent seviye)
  type       FinancialLogType
  description String?

  // Tutarlar
  grossAmount  Decimal @db.Decimal(14, 4)  // Brüt tutar
  taxAmount    Decimal @default(0) @db.Decimal(14, 4)
  feeAmount    Decimal @default(0) @db.Decimal(14, 4) // Hizmet bedeli
  netAmount    Decimal @db.Decimal(14, 4)  // Net tutar (gross - tax - fee)
  currency     Currency @default(USD)

  // Maliyet tarafı (kâr hesaplama)
  costAmount   Decimal @default(0) @db.Decimal(14, 4)
  profitAmount Decimal @default(0) @db.Decimal(14, 4)

  // Kim yaptı
  performedById String? @db.VarChar(36)
  performedBy   String? @db.VarChar(200) // staff adı (snapshot)

  metadata Json? // ek bilgi (iade sebebi, API hata kodu vb.)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([subOrderId])
  @@index([type])
  @@index([createdAt])
  @@map("order_financial_logs")
}

// ─────────────────────────────────────────────────────────────
// 6. WALLET (Kolon Bazlı 8 Bakiye Türü)
// ─────────────────────────────────────────────────────────────

model Wallet {
  id       String   @id @default(uuid())
  userId   String   @unique
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency Currency @default(TRY)

  // ─── 8 Bakiye Kolonu ────────────────────────────────────
  balanceCurrent      Decimal @default(0) @db.Decimal(14, 4) // Güncel
  balanceBonus        Decimal @default(0) @db.Decimal(14, 4) // Bonus
  balanceWithdrawable Decimal @default(0) @db.Decimal(14, 4) // Çekilebilir
  balanceCredit       Decimal @default(0) @db.Decimal(14, 4) // Kredi
  balanceFrozen       Decimal @default(0) @db.Decimal(14, 4) // Bloke
  balanceLottery      Decimal @default(0) @db.Decimal(14, 4) // Çekiliş (SADECE çekilişlerde!)
  balanceCashback     Decimal @default(0) @db.Decimal(14, 4) // Cashback
  balanceCommission   Decimal @default(0) @db.Decimal(14, 4) // Komisyon

  isActive Boolean @default(true)

  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallets")
}

model WalletTransaction {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type         WalletTxType
  balanceField BalanceField  // Hangi kolon etkilendi
  amount       Decimal       @db.Decimal(14, 4)
  balanceAfter Decimal       @db.Decimal(14, 4) // İşlem sonrası o kolonun değeri

  description   String?
  orderId       String?
  order         Order?  @relation(fields: [orderId], references: [id])
  referenceType String? @db.VarChar(50)  // "order", "referral", "manual", "lottery"
  referenceId   String?

  performedById String?
  performedBy   User?   @relation("PerformedBy", fields: [performedById], references: [id])

  paymentTx PaymentTransaction?

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([orderId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

// ─────────────────────────────────────────────────────────────
// 7. REFERRAL SYSTEM
// ─────────────────────────────────────────────────────────────

model ReferralRule {
  id                String        @id @default(uuid())
  name              String        @db.VarChar(100)
  description       String?

  // Gelir Modeli (Image 2): Ürün Satışı / Yeni Üye Kaydı
  incomeModel       ReferralIncomeModel  @default(PRODUCT_SALE)
  // Referans Modeli: ReferansLink / ListeGelir
  referralModel     ReferralModelType    @default(REFERRAL_LINK)
  // Gelir Hesaplama Yöntemi: Satış Fiyatından / Kâr-Stok Maliyeti / Kâr-Güncel Maliyet
  calculationMethod ReferralCalculation  @default(SALE_PRICE)

  // Eski uyumluluk
  calculationBasis  ReferralBasis
  commissionPercent Decimal       @db.Decimal(5, 2)   // Yüzde komisyon
  fixedCommission   Decimal       @default(0) @db.Decimal(14, 4)  // Sabit TL komisyon (% + TL)
  tierLevel         Int           @default(1)

  // Kazanç Sağlayacak Müşteri Tipi (Image 2)
  earnerCustomerType String?  @db.VarChar(50) // null = tümü, "INDIVIDUAL", "CORPORATE"

  // Alışveriş Fiyat Aralığı (Image 2)
  minPurchaseAmount Decimal @default(0) @db.Decimal(14, 4)
  maxPurchaseAmount Decimal @default(0) @db.Decimal(14, 4) // 0 = sınırsız
  minSalesAmount    Decimal @default(0) @db.Decimal(14, 4) // Minimum gelir
  maxCommission     Decimal @default(0) @db.Decimal(14, 4) // Max komisyon

  // Sipariş Adet Sınırı (Image 2)
  orderCountLimit   Int     @default(0) // 0 = sınırsız

  // Geçerlilik Tarihi (Image 2)
  validFrom  DateTime?
  validUntil DateTime?

  // Kendi alışverişinden kazanç sağlayabilir (Image 2 checkbox)
  selfEarningEnabled Boolean @default(false)

  applicableCategoryIds String[]  // UUID dizisi — boş = tümü
  applicableProductIds  String[]  // UUID dizisi — boş = tümü

  isActive Boolean @default(true)

  userReferrals UserReferral[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("referral_rules")
}

model UserReferral {
  id              String @id @default(uuid())
  referrerId      String
  referredUserId  String

  referrer        User   @relation("ReferrerLinks", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser    User   @relation("ReferredLinks", fields: [referredUserId], references: [id], onDelete: Cascade)

  referralRuleId  String?
  referralRule    ReferralRule? @relation(fields: [referralRuleId], references: [id])

  totalEarnings     Decimal @default(0) @db.Decimal(14, 4)
  totalTransactions Int     @default(0)
  isActive          Boolean @default(true)

  transactions ReferralTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([referrerId, referredUserId])
  @@index([referrerId])
  @@map("user_referrals")
}

model ReferralTransaction {
  id              String   @id @default(uuid())
  userReferralId  String
  userReferral    UserReferral @relation(fields: [userReferralId], references: [id], onDelete: Cascade)

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  subOrderId String?
  subOrder   SubOrder? @relation(fields: [subOrderId], references: [id])

  calculationBasis ReferralBasis
  appliedPercent   Decimal @db.Decimal(5, 2)
  baseAmount       Decimal @db.Decimal(14, 4)
  commissionAmount Decimal @db.Decimal(14, 4)

  createdAt DateTime @default(now())

  @@index([userReferralId])
  @@index([orderId])
  @@map("referral_transactions")
}

// ─────────────────────────────────────────────────────────────
// 8. BOT & API PROVIDERS
// ─────────────────────────────────────────────────────────────

model BotProvider {
  id     String            @id @default(uuid())
  tenantIds Json?
  name   String            @db.VarChar(100)
  type   BotProviderType
  status BotProviderStatus @default(ACTIVE)

  apiUrl             String? @db.VarChar(500)
  encryptedApiKey    String? @db.Text
  encryptedApiSecret String? @db.Text

  // Bakiye takibi (Sağlayıcıdaki mevcut bakiyemiz)
  balance            Decimal @default(0) @db.Decimal(14, 4)
  balanceCurrency    Currency @default(USD)
  lastBalanceSync    DateTime?

  priority              Int @default(0)
  maxConcurrentRequests Int @default(10)
  timeoutMs             Int @default(30000)

  // Fallback zinciri
  fallbackProviderId String?
  fallbackProvider   BotProvider?  @relation("BotFallback", fields: [fallbackProviderId], references: [id])
  fallbackOf         BotProvider[] @relation("BotFallback")

  config Json? // ek konfigürasyon

  supportedProducts BotProviderProduct[]
  productProviders  ProductProvider[]
  subOrders         SubOrder[]
  dealerPriorities  DealerApiPriority[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bot_providers")
}

model BotProviderProduct {
  id            String @id @default(uuid())
  botProviderId String
  productId     String
  priority      Int    @default(0)

  externalProductCode String? @db.VarChar(100)
  isActive            Boolean @default(true)

  botProvider BotProvider @relation(fields: [botProviderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([botProviderId, productId])
  @@map("bot_provider_products")
}

/// Ürün ↔ Sağlayıcı ilişkisi (priority ve costPrice ile)
/// Admin bir ürüne birden fazla sağlayıcı atayabilir ve öncelik sırası belirler.
/// Smart Router bu tabloyu okuyarak sipariş yönlendirmesi yapar.
model ProductProvider {
  id         String @id @default(uuid())
  productId  String
  providerId String

  providerProductCode String?  @db.VarChar(200) // O API'nin bu ürünü tanıdığı kendi ID'si
  costPrice           Decimal  @db.Decimal(12, 4) // Bu sağlayıcıdaki alış maliyetimiz
  costCurrency        Currency @default(USD)
  priority            Int      @default(1)      // 1 = en yüksek öncelik
  isActive            Boolean  @default(true)

  product  Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  provider BotProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, providerId])
  @@index([productId, priority])
  @@map("product_providers")
}

// ─────────────────────────────────────────────────────────────
// 9. PAYMENT METHODS
// ─────────────────────────────────────────────────────────────

model PaymentMethod {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(100)
  code        String  @unique @db.VarChar(50) // "wallet", "bank_transfer", "crypto"
  description String?
  iconUrl     String? @db.VarChar(500)

  gatewayConfig Json?

  minAmount  Decimal @default(0) @db.Decimal(12, 2)
  maxAmount  Decimal @default(0) @db.Decimal(12, 2)
  feePercent Decimal @default(0) @db.Decimal(5, 2)
  fixedFee   Decimal @default(0) @db.Decimal(12, 2)

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  tenantIds Json?

  dealerGroupMappings DealerGroupPaymentMethod[]
  categoryRestrictions CategoryPaymentRestriction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_methods")
}

model DealerGroupPaymentMethod {
  id              String @id @default(uuid())
  dealerGroupId   String
  paymentMethodId String
  isAllowed       Boolean @default(true)
  additionalFeePercent Decimal @default(0) @db.Decimal(5, 2)

  dealerGroup   DealerGroup   @relation(fields: [dealerGroupId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([dealerGroupId, paymentMethodId])
  @@map("dealer_group_payment_methods")
}

// ─────────────────────────────────────────────────────────────
// 10. SUPPLIER (Tedarikçi — Muhasebe)
// ─────────────────────────────────────────────────────────────

model Supplier {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(200)
  code        String  @unique @db.VarChar(50) // kısa kod: "SUP-STEAM", "SUP-APPLE"
  contactName String? @db.VarChar(150)
  email       String? @db.VarChar(255)
  phone       String? @db.VarChar(30)
  taxId       String? @db.VarChar(50)         // Vergi no
  address     String?
  country     String? @db.VarChar(50)
  notes       String?

  isActive Boolean @default(true)

  epins EPin[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suppliers")
}

// ─────────────────────────────────────────────────────────────
// 11. AUDIT LOG
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  tenantId   String?
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  category   String      @default("SYSTEM") @db.VarChar(40)
  entityType String?     @db.VarChar(50)
  entityId   String?

  details       Json?
  previousValue Json?
  newValue      Json?

  ipAddress String? @db.VarChar(45)
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
  @@index([category, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// 12. İNDİRİM KUPONU (#19)
// ─────────────────────────────────────────────────────────────

model DiscountCoupon {
  id          String       @id @default(uuid())
  tenantIds   Json?
  code        String       @unique @db.VarChar(50)
  name        String?      @db.VarChar(200)
  description String?
  type        CouponType   @default(PERCENTAGE)
  value       Decimal      @db.Decimal(14, 4) // % veya sabit tutar

  currency         Currency @default(USD)
  minOrderAmount   Decimal  @default(0) @db.Decimal(14, 4)
  maxDiscountAmount Decimal @default(0) @db.Decimal(14, 4) // 0 = sınırsız

  maxUsageTotal   Int @default(0)  // 0 = sınırsız
  maxUsagePerUser Int @default(1)
  currentUsage    Int @default(0)

  applicableProductIds  String[]
  applicableCategoryIds String[]
  applicableUserRoles   String[] // ["CUSTOMER","DEALER"] boş = tümü
  targetAudience        String   @default("ALL") @db.VarChar(50)

  showAsBanner      Boolean @default(false)
  showAsPopup       Boolean @default(false)
  bannerTitle       String? @db.VarChar(200)
  bannerDescription String?
  popupTitle        String? @db.VarChar(200)
  popupDescription  String?
  popupCta          String? @db.VarChar(120)
  popupRedirectUrl  String? @db.VarChar(500)
  popupDelaySeconds Int     @default(10)
  popupFrequency    String  @default("SESSION") @db.VarChar(30)
  popupPageScope    String  @default("ALL") @db.VarChar(30)
  popupCategoryIds  String[]

  status    CouponStatus @default(ACTIVE)
  validFrom  DateTime?
  validUntil DateTime?

  usages      CouponUsage[]
  userCoupons UserCoupon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("discount_coupons")
}

model CouponUsage {
  id       String @id @default(uuid())
  couponId String
  coupon   DiscountCoupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  userId         String?
  orderId        String?
  discountAmount Decimal @db.Decimal(14, 4)

  createdAt DateTime @default(now())

  @@index([couponId])
  @@index([userId])
  @@map("coupon_usages")
}

// ─────────────────────────────────────────────────────────────
// 13. FATURA SİSTEMİ (#21 — BirFatura + PDF Yurt Dışı)
// ─────────────────────────────────────────────────────────────

/// Haftalık toplama: 1 haftada 1 müşterinin siparişlerini toplayıp keser.
/// E-faturada maliyet yazılır, kar edilen tutara hizmet bedeli + %20 KDV.
model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique @db.VarChar(30)
  userId        String
  user          User   @relation(fields: [userId], references: [id])

  type   InvoiceType   @default(DEFAULT)
  status InvoiceStatus @default(DRAFT)

  // Tutarlar
  subtotal    Decimal @db.Decimal(14, 4)
  serviceFee  Decimal @default(0) @db.Decimal(14, 4) // Hizmet bedeli
  taxRate     Decimal @default(20) @db.Decimal(5, 2)  // %20 KDV
  taxAmount   Decimal @db.Decimal(14, 4)
  totalAmount Decimal @db.Decimal(14, 4)
  currency    Currency @default(TRY)

  // Müşteri bilgileri (snapshot)
  customerName    String  @db.VarChar(200)
  customerEmail   String  @db.VarChar(255)
  customerAddress String?
  taxId           String? @db.VarChar(50) // Vergi No

  // Entegrasyon
  externalInvoiceId String? @db.VarChar(200) // BirFatura ID
  pdfUrl            String? @db.VarChar(500)

  // Dönem (haftalık toplama)
  periodStart DateTime?
  periodEnd   DateTime?

  notes String?

  items InvoiceItem[]

  billingEntityId String?
  billingEntity   BillingEntity? @relation(fields: [billingEntityId], references: [id])

  issuedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id        String @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  orderId     String?
  subOrderId  String?
  productName String  @db.VarChar(200)
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 4) // E-faturada maliyet yazılır, satış fiyatı DEĞİL
  totalPrice  Decimal @db.Decimal(14, 4)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─────────────────────────────────────────────────────────────
// 14. SLIDER SİSTEMİ (#22)
