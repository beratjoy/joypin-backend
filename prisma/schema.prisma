/// Çok dilli blog çevirisi — her BlogPost'un birden fazla dil versiyonu olabilir
model BlogTranslation {
  id             String   @id @default(uuid())
  blogPostId     String
  blogPost       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  languageCode   String   @db.VarChar(10) // "tr", "en", "de", "fr"
  title          String   @db.VarChar(300)
  content        String   @db.Text
  excerpt        String?  @db.VarChar(500)

  seoTitle       String?  @db.VarChar(200)
  seoDescription String?  @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([blogPostId, languageCode])
  @@index([languageCode])
  @@map("blog_translations")
}

// ─────────────────────────────────────────────────────────────
// 16. ÇEKİLİŞ SİSTEMİ (#13 — Yayıncılar oluşturur, admin onaylar)
// ─────────────────────────────────────────────────────────────

model Lottery {
  id          String  @id @default(uuid())
  title       String  @db.VarChar(200)
  description String?
  imageUrl    String? @db.VarChar(500)

  createdById String // Yayıncı (Publisher user)

  entryPrice Decimal  @db.Decimal(14, 4) // LOTTERY bakiyesinden düşülür
  currency   Currency @default(TRY)

  maxEntries Int @default(0) // 0 = sınırsız

  prizeDescription String?
  prizeValue       Decimal? @db.Decimal(14, 4)

  status       String   @default("DRAFT") @db.VarChar(20)
  approvedById String?
  approvedAt   DateTime?

  startDate DateTime?
  endDate   DateTime?
  drawDate  DateTime?

  winnerId String?

  entries LotteryEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdById])
  @@map("lotteries")
}

model LotteryEntry {
  id        String  @id @default(uuid())
  lotteryId String
  lottery   Lottery @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  userId    String

  ticketNumber String  @db.VarChar(20)
  isWinner     Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([lotteryId, userId])
  @@index([lotteryId])
  @@map("lottery_entries")
}

// ─────────────────────────────────────────────────────────────
