}

// ─────────────────────────────────────────────────────────────
// 15. BLOG SİSTEMİ (#23)
// ─────────────────────────────────────────────────────────────

model BlogCategory {
  id   String @id @default(uuid())
  name String @db.VarChar(100)
  slug String @unique @db.VarChar(120)

  posts BlogPost[]

  createdAt DateTime @default(now())

  @@map("blog_categories")
}

model BlogPost {
  id         String @id @default(uuid())
  tenantIds  Json?
  title      String @db.VarChar(300)
  slug       String @unique @db.VarChar(350)
  content    String @db.Text
  excerpt    String? @db.VarChar(500)
  coverImage String? @db.VarChar(500)
  imageUrl   String? @db.VarChar(500) // TrySoro'dan gelen görsel

  categoryId String?
  category   BlogCategory? @relation(fields: [categoryId], references: [id])
  authorId   String?

  seoTitle       String? @db.VarChar(200)
  seoDescription String? @db.VarChar(500)

  status      String @default("DRAFT") @db.VarChar(20) // DRAFT, PUBLISHED
  isPublished Boolean @default(false)
